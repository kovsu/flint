{
	"name": "@flint/workspace",
	"version": "0.12.0",
	"private": true,
	"description": "[Experimental] Monorepo for Flint: a fast, friendly linter. ❤️‍🔥",
	"homepage": "https://flint.fyi",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/flint-fyi/flint.git"
	},
	"license": "MIT",
	"author": {
		"name": "Josh Goldberg ✨",
		"email": "npm@joshuakgoldberg.com"
	},
	"type": "module",
	"scripts": {
		"build": "tsdown",
		"clean": "rimraf -g \"**/node_modules\"",
		"flint": "node packages/flint/bin/index.js",
		"flint:cache-ignore": "node packages/flint/bin/index.js --cache-ignore",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:knip:prod": "knip --strict",
		"prepare": "husky",
		"start:site": "pnpm --filter=site prebuild && pnpm --filter=site start",
		"test": "vitest"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "catalog:dev",
		"@changesets/cli": "catalog:dev",
		"@eslint-community/eslint-plugin-eslint-comments": "catalog:dev",
		"@eslint/js": "catalog:dev",
		"@eslint/markdown": "catalog:dev",
		"@flint.fyi/node": "workspace:^",
		"@flint.fyi/performance": "workspace:^",
		"@flint.fyi/plugin-flint": "workspace:^",
		"@flint.fyi/spelling": "workspace:^",
		"@flint.fyi/ts-patch": "workspace:^",
		"@types/node": "catalog:dev",
		"@vitest/coverage-v8": "catalog:dev",
		"@vitest/eslint-plugin": "catalog:dev",
		"console-fail-test": "catalog:dev",
		"eslint": "catalog:dev",
		"eslint-plugin-jsdoc": "catalog:dev",
		"eslint-plugin-jsonc": "catalog:dev",
		"eslint-plugin-n": "catalog:dev",
		"eslint-plugin-package-json": "catalog:dev",
		"eslint-plugin-perfectionist": "catalog:dev",
		"eslint-plugin-regexp": "catalog:dev",
		"eslint-plugin-yml": "catalog:dev",
		"flint": "workspace:^",
		"husky": "catalog:dev",
		"jiti": "catalog:dev",
		"knip": "catalog:dev",
		"lint-staged": "catalog:dev",
		"prettier": "catalog:dev",
		"prettier-plugin-astro": "catalog:dev",
		"prettier-plugin-curly": "catalog:dev",
		"prettier-plugin-packagejson": "catalog:dev",
		"prettier-plugin-sentences-per-line": "catalog:dev",
		"prettier-plugin-sh": "catalog:dev",
		"rimraf": "catalog:dev",
		"tsdown": "catalog:dev",
		"typescript": "catalog:dev",
		"typescript-eslint": "catalog:dev",
		"vitest": "catalog:dev"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=24.0.0"
	}
}
